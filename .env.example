# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/digital_memory?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=digital_memory

# Redis (for queue)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Services
INGESTION_SERVICE_PORT=8001
API_SERVICE_PORT=8000
AI_SERVICE_PORT=8002

# OpenAI API
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Slack
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token

# GitHub
GITHUB_TOKEN=ghp_your_github_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Security
JWT_SECRET=your_jwt_secret_key_change_me
API_KEY=your_api_key_change_me

# Logging
LOG_LEVEL=info

# Environment
ENV=development
